a:["$","$L19",null,{"title":"Trending TV Shows","subtitle":"Must-watch series currently airing","children":[["$","$L1a","224372",{"movie":{"adult":false,"backdrop_path":"/7mkUu1F2hVUNgz24xO8HPx0D6mK.jpg","id":224372,"name":"A Knight of the Seven Kingdoms","original_name":"A Knight of the Seven Kingdoms","overview":"A century before the events of Game of Thrones, two unlikely heroes wandered Westeros: a young, naive but courageous knight, Ser Duncan the Tall, and his diminutive squire, Egg. Set in an age when the Targaryen line still holds the Iron Throne and the last dragon has not yet passed from living memory, great destinies, powerful foes, and dangerous exploits await these improbable and incomparable friends.","poster_path":"/k8yARbD9iYn2nRX2HvsopfKDN2r.jpg","media_type":"tv","original_language":"en","genre_ids":[18,10765,10759],"popularity":398.4544,"first_air_date":"2026-01-18","vote_average":8.516,"vote_count":310,"origin_country":["US"]}}],["$","$L1a","106379",{"movie":{"adult":false,"backdrop_path":"/coaPCIqQBPUZsOnJcWZxhaORcDT.jpg","id":106379,"name":"Fallout","original_name":"Fallout","overview":"The story of haves and have-nots in a world in which there's almost nothing left to have. 200 years after the apocalypse, the gentle denizens of luxury fallout shelters are forced to return to the irradiated hellscape their ancestors left behind — and are shocked to discover an incredibly complex, gleefully weird, and highly violent universe waiting for them.","poster_path":"/c15BtJxCXMrISLVmysdsnZUPQft.jpg","media_type":"tv","original_language":"en","genre_ids":[10759,10765],"popularity":99.0735,"first_air_date":"2024-04-10","vote_average":8.141,"vote_count":2574,"origin_country":["US"]}}],["$","$L1a","273977",{"movie":{"adult":false,"backdrop_path":"/qy8gJEwspR7L5WZn4e8ItwK8m23.jpg","id":273977,"name":"The Art of Sarah","original_name":"레이디 두아","overview":"A body found in the middle of town. A luxe label on the rise. A detective tests every stitch of a woman's